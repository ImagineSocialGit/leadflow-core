APP_NAME="LeadflowCore"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://DOMAIN
ASSET_URL="${APP_URL}"

ROOT_DOMAIN=https://DOMAIN.com
WEBINAR_APP_URL=https://webinar.DOMAIN
CRM_APP_URL=https://crm.DOMAIN

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

################################
# USERS
################################

STAGING_USER=
STAGING_PASSWORD=

SETUP_USER_NAME=
SETUP_USER_EMAIL=
SETUP_USER_PASSWORD=

CRM_LOGIN_MAX_ATTEMPTS=5
CRM_LOGIN_DECAY_SECONDS=60

################################
# LOGGING
################################

LOG_CHANNEL=errorlog
LOG_STACK=errorlog
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

################################
# DATABASE
################################

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

################################
# CACHE
################################

CACHE_STORE=redis
CACHE_PREFIX=laravel_cache

################################
# SESSIONS
################################

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

################################
# QUEUES
################################

QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

WEBINAR_REGISTRATION_QUEUE=webinars
WEBINAR_WEBHOOK_QUEUE=webhooks
WEBINAR_REMINDER_QUEUE=notifications
WEBINAR_CONFIRMATION_MESSAGE_QUEUE=notifications
WEBINAR_FOLLOWUP_QUEUE=notifications

################################
# REDIS
################################

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=

################################
# BROADCASTING
################################

BROADCAST_CONNECTION=log

################################
# FILE STORAGE
################################

FILESYSTEM_DISK=spaces

DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=
CDN_URL=

################################
# EMAIL
################################

MAIL_MAILER=resend
MAIL_HOST=api.resend.com
MAIL_PORT=443
MAIL_SCHEME=https
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

RESEND_API_KEY=

################################
# SMS
################################

TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

TWILIO_VIRTUAL_PHONE=

################################
# WEBINARS
################################

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

ZOOM_BASE_URL=https://api.zoom.us/v2
ZOOM_OAUTH_URL=https://zoom.us/oauth/token
ZOOM_OAUTH_TOKEN_CACHE_KEY=zoom_access_token
ZOOM_OAUTH_TOKEN_TTL_SECONDS=3500

ZOOM_WEBHOOK_MAX_TIMESTAMP_DRIFT_SECONDS=300
ZOOM_WEBHOOK_REPLAY_CACHE_TTL_SECONDS=600

WEBINAR_TEST_SCHEDULING_ENABLED=false
WEBINAR_TEST_DELAY_STEP_SECONDS=60

################################
# HORIZON
################################

HORIZON_PREFIX=horizon
HORIZON_MASTER_MEMORY_LIMIT=64
HORIZON_WAIT_THRESHOLD_DEFAULT=60
HORIZON_MAX_PROCESSES=1
HORIZON_MEMORY=128
HORIZON_TRIES=1
HORIZON_TIMEOUT=60

HORIZON_PRODUCTION_MAX_PROCESSES=10
HORIZON_STAGING_MAX_PROCESSES=3
HORIZON_LOCAL_MAX_PROCESSES=3

HORIZON_BALANCE_MAX_SHIFT=1
HORIZON_BALANCE_COOLDOWN=3

HORIZON_SUPERVISOR_1_QUEUES=default,webinars,emails,notifications,webhooks

################################
# FRONTEND
################################

VITE_APP_NAME="${APP_NAME}"

################################
# SCHEDULING TEST
################################

WEBINAR_REMINDER_TESTING=false