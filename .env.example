APP_NAME="LeadflowCore"
APP_ENV=local
APP_KEY=
APP_DEBUG=true

APP_URL=https://webinar.domain.com

WEBINAR_APP_URL=https://webinar.domain.com
CRM_APP_URL=https://crm.domain.com

# ASSET_URL=https://cdn.domain.com <-- Reserve for cdn in future if used

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12


################################

# USERS

################################

STAGING_USER=
STAGING_PASSWORD=

#ADMIN_USER=
#ADMIN_PASSWORD=

################################

# LOGGING

################################

LOG_CHANNEL=errorlog
LOG_STACK=errorlog
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

################################

# DATABASE (MySQL 8 - separate server in production)

################################

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

################################

# CACHE (Redis)

################################

CACHE_STORE=redis
CACHE_PREFIX=laravel_cache

################################

# SESSIONS (Redis)

################################

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

################################

# QUEUES (Redis + Horizon)

################################

QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

################################

# REDIS

################################

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=

################################

# BROADCASTING

################################

BROADCAST_CONNECTION=log

################################

# FILE STORAGE (DigitalOcean Spaces)

################################

FILESYSTEM_DISK=spaces

DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=is-do-cdn
DO_CDN_PREFIX=https://is-do-cdn.nyc3.digitaloceanspaces.com

################################

# EMAIL (Resend)

################################

MAIL_MAILER=resend
MAIL_HOST=api.resend.com
MAIL_PORT=443
MAIL_SCHEME=https
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

RESEND_API_KEY=

################################

# SMS (Twilio)

################################

TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

################################

# WEBINARS (Zoom)

################################

ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_WEBHOOK_SECRET=

################################

# HORIZON

################################

HORIZON_PREFIX=horizon

################################

# FRONTEND

################################

VITE_APP_NAME="${APP_NAME}"

################################

# SCHEDULING TEST

################################

WEBINAR_REMINDER_TESTING=true